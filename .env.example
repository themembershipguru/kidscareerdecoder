# Copy to `.env` (gitignored). Never commit real passwords or keys.

# Supabase → Project Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your database password (set/reset under Database settings).
#
# Direct connection (port 5432) — fine for a single Node server:
# postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
#
# If the password contains @ : / ? # etc., URL-encode it (e.g. @ → %40).
#
# Pooler (port 6543) — better for many short-lived connections / serverless:
# postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

JWT_SECRET=use-a-long-random-string-in-production

PORT=3001

# AI for quiz completion (used when API runs from server/index.js or backend/)
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ML_SERVICE_URL=http://localhost:5001

# Optional: full API base including /api (for `npm run build` / preview without proxy).
# Dev default: Vite proxies /api → http://localhost:5000 (run `npm run backend` in another terminal).
# VITE_API_URL=http://localhost:5000/api
